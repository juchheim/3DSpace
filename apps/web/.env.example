# @3dspace/web — frontend environment (Vercel / local Next.js)
# Full template: ../../.env.example
# Status matrix: ../../docs/planning/mvp/MVP_STATUS.md

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://127.0.0.1:8080

# From the same Clerk app in the dashboard — do not use the docs sample pk_test_verified-python key.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Required for Clerk middleware on the Next.js server (must pair with the publishable key above).
CLERK_SECRET_KEY=
# Optional overrides (defaults use NEXT_PUBLIC_APP_URL + /sign-in and /sign-up):
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=http://127.0.0.1:3000/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=http://127.0.0.1:3000/sign-up
NEXT_PUBLIC_LIVEKIT_URL=

DEFAULT_VIEW_MODE=3d
DEFAULT_3D_QUALITY=low
NEXT_PUBLIC_ENABLE_WALL_OBJECTS=true
NEXT_PUBLIC_ENABLE_WALL_WEB_LINKS=true
NEXT_PUBLIC_ENABLE_WALL_WEB_EMBEDS=false
NEXT_PUBLIC_ENABLE_WALL_SCREEN_SHARE=true
NEXT_PUBLIC_ENABLE_CLASSROOM_LESSONS=false
NEXT_PUBLIC_ENABLE_WHISPER=false

NEXT_PUBLIC_SENTRY_DSN=

# Production (Vercel) typically also set:
# NEXT_PUBLIC_APP_URL, NEXT_PUBLIC_API_URL, NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY,
# NEXT_PUBLIC_LIVEKIT_URL
