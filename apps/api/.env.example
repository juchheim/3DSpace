# @3dspace/api — backend environment (Koyeb / local API)
# Full template: ../../.env.example
# Status matrix: ../../docs/planning/mvp/MVP_STATUS.md

NODE_ENV=development
HOST=127.0.0.1
PORT=8080
API_PUBLIC_URL=http://127.0.0.1:8080
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
# Production examples:
# CORS_ALLOWED_ORIGINS=https://3d-space-seven.vercel.app,https://*.vercel.app

CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

MONGODB_URI=
MONGODB_DB_NAME=3dspace

LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_PUBLIC_BASE_URL=
# Set to true only when the bucket/CDN at OBJECT_STORAGE_PUBLIC_BASE_URL allows anonymous GET.
OBJECT_STORAGE_PUBLIC_READ=false

# Operator uploader at http://localhost:3000/dev/world-skin-upload (set your password locally only)
WORLD_SKIN_UPLOADER_PASSWORD=

AVATAR_STATE_SEND_HZ=12
AVATAR_INTERPOLATION_MS=120
MAX_ROOM_PARTICIPANTS=30
SESSION_JOIN_RATE_LIMIT_PER_MINUTE=20

DEFAULT_VIEW_MODE=3d
DEFAULT_3D_QUALITY=low
ENABLE_2D_ANALOG=true
ENABLE_WALL_ATTACHMENTS=true
ENABLE_WALL_OBJECTS=true
WALL_OBJECT_CREATION_DEFAULT=teacher-only
WALL_OBJECT_MAX_ACTIVE_PER_ROOM=20
WALL_OBJECT_MAX_ACTIVE_LIVE_SHARES=4
WALL_OBJECT_MAX_IMAGE_BYTES=10485760
WALL_OBJECT_MAX_VIDEO_BYTES=262144000
WALL_OBJECT_MAX_AUDIO_BYTES=52428800
WALL_OBJECT_ALLOWED_IMAGE_TYPES=image/png,image/jpeg,image/webp
WALL_OBJECT_ALLOWED_VIDEO_TYPES=video/mp4,video/webm
WALL_OBJECT_ALLOWED_AUDIO_TYPES=audio/mpeg,audio/mp4,audio/wav,audio/webm
ENABLE_WALL_WEB_LINKS=true
ENABLE_WALL_WEB_EMBEDS=false
WALL_WEB_EMBED_ALLOWLIST=
ENABLE_WALL_SCREEN_SHARE=true
ENABLE_WALL_STUDENT_UPLOADS=false
ENABLE_WALL_STUDENT_LIVE_SHARES=false
ENABLE_CLASSROOM_LESSONS=false
ENABLE_BREAKOUT_PODS=false
ENABLE_ROOM_OBJECTS=false
ENABLE_WORKFORCE_TRAINING=false
ENABLE_FREE_FOR_ALL=false
ENABLE_FREE_FOR_ALL_BUILDING=false
BUILD_PLACEMENT_RATE_LIMIT_PER_MINUTE=600
# Required when ENABLE_FREE_FOR_ALL=true — shared password for creating/joining Free-for-All rooms
FREE_FOR_ALL_PASSWORD=
ENABLE_AI_MEETING_NOTES=false
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_SUMMARY_MODEL=gpt-4.1
AI_MEETING_NOTES_MAX_DURATION_MINUTES=120
AI_MEETING_NOTES_STORAGE_PREFIX=meeting-notes/
ENABLE_WHITEBOARDS=true
WHITEBOARD_COMPACTION_TICK_SECONDS=30
WHITEBOARD_SNAPSHOT_AT_STROKES=500
WHITEBOARD_MAX_POINTS_PER_STROKE=2000
WHITEBOARD_MAX_ACTIVE_PER_ROOM=4
WHITEBOARD_STORAGE_PREFIX=whiteboards/
ENABLE_SHARED_BROWSERS=false
SHARED_BROWSER_VIEWPORT_WIDTH=1280
SHARED_BROWSER_VIEWPORT_HEIGHT=720
SHARED_BROWSER_MAX_ACTIVE_PER_ROOM=2
SHARED_BROWSER_IDLE_PAUSE_MINUTES=15
SHARED_BROWSER_MAX_NAVIGATIONS_PER_USER_PER_MINUTE=20
SHARED_BROWSER_BLOCKED_HOST_SUFFIXES=
SHARED_BROWSER_LAZY_START=true
SHARED_BROWSER_PAUSE_WHEN_ROOM_EMPTY=true
# Hyperbeam (required in production when ENABLE_SHARED_BROWSERS=true)
HYPERBEAM_API_KEY=
HYPERBEAM_API_BASE=https://engine.hyperbeam.com
SHARED_BROWSER_HYPERBEAM_QUALITY=sharp
SHARED_BROWSER_HYPERBEAM_FRAMERATE=30
SHARED_BROWSER_HYPERBEAM_REGION=
# Optional Hyperbeam region: NA, EU, or AS only (omit for default NA)

# --- AI 3D Object Generator (Free-for-All) ---
ENABLE_AI_OBJECT_GENERATION=false
AI_OBJECT_PROVIDER=procedural
MESHY_API_KEY=
OPENAI_AI_OBJECT_COMPOSER_MODEL=gpt-4.1
AI_OBJECT_MESHY_REFINE_TEXTURES=true
AI_OBJECT_STORAGE_PREFIX=ai-objects/
AI_OBJECT_MAX_PROMPT_CHARS=500
AI_OBJECT_MESHY_TIMEOUT_SEC=300
AI_OBJECT_MAX_JOBS_PER_USER_PER_DAY=20
AI_OBJECT_RETENTION_DAYS=30
AI_OBJECT_USE_TEST_FIXTURE=false

ENABLE_WORLD_SKINS=false
ENABLE_STUDENT_MEDIA_PERMISSIONS=false

SPATIAL_AUDIO_ENABLED=true
SPATIAL_AUDIO_DISTANCE_MODEL=inverse
SPATIAL_AUDIO_REF_DISTANCE=1
SPATIAL_AUDIO_MAX_DISTANCE=24
SPATIAL_AUDIO_ROLLOFF_FACTOR=1.4

MEDIA_DEFAULT_CAMERA_ENABLED=false
MEDIA_DEFAULT_MIC_ENABLED=false
MEDIA_MAX_VIDEO_WIDTH=640
MEDIA_MAX_VIDEO_HEIGHT=360
MEDIA_MAX_VIDEO_FPS=15

SENTRY_DSN=

# Production (Koyeb) required when NODE_ENV=production:
# API_PUBLIC_URL, CORS_ALLOWED_ORIGINS, CLERK_SECRET_KEY, MONGODB_URI,
# LIVEKIT_URL, LIVEKIT_API_KEY, LIVEKIT_API_SECRET
# Shared browser note: when ENABLE_SHARED_BROWSERS=true in production, HYPERBEAM_API_KEY is required (see IMPL_FREE_FOR_ALL_SHARED_BROWSER_HYPERBEAM.md).
# Plus object storage vars when ENABLE_WALL_ATTACHMENTS=true
