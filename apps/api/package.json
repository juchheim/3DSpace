{
  "name": "@3dspace/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx --conditions development src/server.ts",
    "build": "tsc -p tsconfig.json && node scripts/copy-builtin-catalog.mjs",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "openapi": "npm run build && node dist/openapi.js"
  },
  "dependencies": {
    "@3dspace/contracts": "0.1.0",
    "@3dspace/room-engine": "0.1.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@clerk/backend": "^1.5.0",
    "@fastify/cors": "^11.2.0",
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/extensions": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "@livekit/rtc-node": "^0.13.29",
    "draco3dgltf": "^1.5.7",
    "fastify": "^5.8.5",
    "image-size": "^2.0.2",
    "livekit-server-sdk": "^2.5.3",
    "meshoptimizer": "^1.1.1",
    "mongoose": "^8.4.3",
    "openai": "^6.39.0",
    "puppeteer": "^24.43.1",
    "sharp": "^0.34.5",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "tsx": "^4.15.7",
    "typescript": "^5.5.2"
  }
}
