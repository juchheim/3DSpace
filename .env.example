# 3DSpace environment template
# Copy to `.env.local` at the repository root for local development:
#   cp .env.example .env.local
#
# Authoritative matrix (platform, required, defaults, status): docs/planning/mvp/MVP_STATUS.md
# Production deployment steps: docs/planning/mvp/DEPLOYMENT_CHECKLIST.md
#
# App-specific subsets:
#   apps/api/.env.example  — backend (Koyeb)
#   apps/web/.env.example  — frontend (Vercel)

# --- Runtime ---
NODE_ENV=development
HOST=127.0.0.1
PORT=8080

# --- Public URLs ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://127.0.0.1:8080
API_PUBLIC_URL=http://127.0.0.1:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Clerk (leave empty locally for dev identity headers) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# --- MongoDB Atlas (leave empty locally to use in-memory repository) ---
MONGODB_URI=
MONGODB_DB_NAME=3DSpace

# --- LiveKit (leave empty locally for multi-tab BroadcastChannel fallback) ---
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=

# --- S3-compatible object storage (leave empty locally for deterministic dev URLs) ---
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_PUBLIC_BASE_URL=

# --- Session / room tuning (backend) ---
AVATAR_STATE_SEND_HZ=12
AVATAR_INTERPOLATION_MS=120
MAX_ROOM_PARTICIPANTS=30
SESSION_JOIN_RATE_LIMIT_PER_MINUTE=20

# --- Client defaults (also used by Next.js build when set on Vercel) ---
DEFAULT_VIEW_MODE=3d
DEFAULT_3D_QUALITY=low
ENABLE_2D_ANALOG=true
ENABLE_WALL_ATTACHMENTS=true

# --- Spatial audio ---
SPATIAL_AUDIO_ENABLED=true
SPATIAL_AUDIO_DISTANCE_MODEL=inverse
SPATIAL_AUDIO_REF_DISTANCE=1
SPATIAL_AUDIO_MAX_DISTANCE=24
SPATIAL_AUDIO_ROLLOFF_FACTOR=1.4

# --- Media capture defaults ---
MEDIA_DEFAULT_CAMERA_ENABLED=false
MEDIA_DEFAULT_MIC_ENABLED=false
MEDIA_MAX_VIDEO_WIDTH=640
MEDIA_MAX_VIDEO_HEIGHT=360
MEDIA_MAX_VIDEO_FPS=15

# --- Observability (optional) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
