{
  "name": "3dspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:stop": "node scripts/dev-stop.mjs",
    "dev:api": "npm --workspace @3dspace/api run dev",
    "dev:web": "npm --workspace @3dspace/web run dev",
    "build": "npm run build -w @3dspace/contracts && npm run build -w @3dspace/room-engine && npm run build -w @3dspace/api && npm run build -w @3dspace/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "openapi": "npm run build -w @3dspace/contracts && npm --workspace @3dspace/api run openapi"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.14.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.9.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^5.5.2",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@10.12.4+sha512.5ea8b0deed94ed68691c9bad4c955492705c5eeb8a87ef86bc62c74a26b037b08ff9570f108b2e4dbd1dd1a9186fea925e527f141c648e85af45631074680184"
}
